---
import Layout from "@/layouts/main.astro";
import { Button } from "@/components/ui/button";
import { Image } from "astro:assets";
import HeroDark from "../assets/hero-dark.svg";
import HeroLight from "../assets/hero-light.svg";
---

<Layout>
  <!-- Changed justify-center to justify-start and added top padding (pt-24) -->
  <div class="flex flex-col min-h-svh p-6 pt-64 items-center justify-start text-center gap-6">
    <Image src={HeroDark} alt="Hero illustration" class="w-full max-w-4xl hidden dark:block" />
    <Image src={HeroLight} alt="Hero illustration" class="w-full max-w-4xl dark:hidden" />
    
    <h2 class="text-3xl font-serif max-w-xl balance">
      is a teen dev based in Luxembourg, who loves to tinker with hardware and create polished websites.
    </h2>
  </div>
  <!-- Section with a couple projects and a couple brlog posts -->
  <div class="flex-col columns-2">
    <div>
      <h3 class="text-7xl font-serif">Projects</h3>
    </div>
    <div>
      <h3 class="text-7xl font-serif">Blog</h3>
    </div>
  </div>
</Layout>